<div class="collection-grid-wrapper-{{ section.id }}">
  <div class="collection-grid">

    {% for block in section.blocks %}
      <a href="{{ block.settings.collection_link }}" class="collection-card">

        {% if block.settings.collection_image %}
          <img
            src="{{ block.settings.collection_image | image_url: width: 600 }}"
            alt="{{ block.settings.collection_title }}"
            loading="lazy"
          >
        {% endif %}

        <div class="overlay">
          <h3>{{ block.settings.collection_title }}</h3>
        </div>

      </a>
    {% endfor %}

  </div>
</div>

<style>
      
.collection-grid-wrapper-{{ section.id }}{
  max-width:1200px;
  margin:auto;
  padding:40px 20px;
}

.collection-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:20px;
}

.collection-card{
  position:relative;
  display:block;
  overflow:hidden;
  border-radius:16px;
  text-decoration:none;
}

.collection-card img{
  width:100%;
  height:300px;
  object-fit:cover;
  display:block;
  transition:.4s;
}

.collection-card:hover img{
  transform:scale(1.08);
}

.overlay{
  position:absolute;
  inset:0;
  display:flex;
  align-items:end;
  padding:20px;
}

.overlay h3{
  color:#fff;
  font-size:22px;
  margin:0;
}

@media(max-width:991px){
  .collection-grid{
    grid-template-columns:repeat(2,1fr);
  }
}

@media(max-width:576px){
  .collection-grid{
    grid-template-columns:1fr;
  }
}
</style>

{% schema %}
{
  "name":"Collection Grid",
  "settings":[],
  "blocks":[
    {
      "type":"collection_item",
      "name":"Collection Item",
      "settings":[
        {
          "type":"image_picker",
          "id":"collection_image",
          "label":"Collection Image"
        },
        {
          "type":"text",
          "id":"collection_title",
          "label":"Collection Title"
        },
        {
          "type":"url",
          "id":"collection_link",
          "label":"Collection Link"
        }
      ]
    }
  ],
  "presets":[
    {
      "name":"Collection Grid"
    }
  ]
}
{% endschema %}