<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/gh/kenwheeler/slick@1.8.1/slick/slick.css"/>
<!-- Add the slick-theme.css if you want default styling -->
<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/gh/kenwheeler/slick@1.8.1/slick/slick-theme.css"/>
<script src="https://code.jquery.com/jquery-3.7.1.slim.min.js" integrity="sha256-kmHvs0B+OpCW5GVHUNjv9rOmY0IvSIRcf7zGUDTDQM8=" crossorigin="anonymous"></script>
<script type="text/javascript" src="https://cdn.jsdelivr.net/gh/kenwheeler/slick@1.8.1/slick/slick.min.js"></script>


<style>
        .main-div {
        width: 100%;
    }

    .slide {
        position: relative;
    }

    .slide img {
        width: 100%;
        height: 300px;
        object-fit: cover;
    }

    .text-side {
        position: absolute;
        top: 50%;
        left: 50px;
        transform: translateY(-50%);
        color: white;
        max-width: 400px;
    }

    .text-side .round-red{
        background-color:red;
        color:white;
        padding:10px 20px;
        border-radius:50px;
    }
    .text-side h3 {
        font-size: 28px;
        margin: 10px 0;
    }

    .text-side p {
        font-size: 14px;
        margin: 0;
        background-color:transparent;
        color:black;

    .text-side button {
        margin-right: 10px;
        padding: 8px 15px;
        border: none;
        cursor: pointer;
    }
    .text-side .shopnow{
        background-color:red;
        color:white;
        padding:10px 20px;
        border-radius:50px;
    }
    .text-side .lookbook{
        background-color:white;
        color:black;
        border:1px solid black;
        padding:10px 20px;
        border-radius:50px;
    }
}
</style> 

<div class="main-div">
    {% for block in section.blocks %}
    <div class="slide">
        <img src="{{ block.settings.slider_image | img_url: '' }}" />

        <div class="text-side" style="padding-top:10px; padding-bottom:7px">
            <span class="round-red">New Season 2026</span>
            <h3 style="color:black; font-size:45px;">Step Into <span style="color:red;">Style</span> This Season</h3>
            <p>Discover the latest collection of premium sneakers and footwear — crafted for comfort, built for style.</p>
            <button class="shopnow">Shop Now</button>
            <button class="lookbook">View Lookbook</button>
        </div>
    </div>
    {% endfor %}
</div>

{% schema %}
{
    "name": "custom-slider",
    "settings": [],
    "blocks":[
        {
            "type": "slider",
            "name":"slider",
            "settings": [
                {
                    "type": "image_picker",
                    "id": "slider_image",
                    "label": "select_image"
                },
                {
                    "type": "text",
                    "id": "image_text",
                    "label": "enter text"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "custom-slider"
        }
    ]
}
{% endschema %}

<script>
    $(document).ready(function(){
        $('.main-div').slick({
            dots: true,
            infinite: true,
            speed: 500,
            slidesToShow: 1,
            autoplay: true,         
            autoplaySpeed: 2000,     
            arrows: true            
        });
    });    
</script>