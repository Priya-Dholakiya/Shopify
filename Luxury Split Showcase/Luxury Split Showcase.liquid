<section class="split-showcase-{{ section.id }}">

  <div class="left-panel">
    <h2>{{ section.settings.heading }}</h2>

    {% for block in section.blocks %}
      <a href="#item-{{ block.id }}" class="nav-item">
        {{ block.settings.title }}
      </a>
    {% endfor %}
  </div>


  <div class="right-panel">

    {% for block in section.blocks %}

      <div class="showcase-item" id="item-{{ block.id }}">

        <div class="image-box">
          <img
            src="{{ block.settings.image | image_url: width: 900 }}"
            alt="{{ block.settings.title }}"
          >
        </div>

        <div class="content-box">
          <h3>{{ block.settings.title }}</h3>

          <p>{{ block.settings.description }}</p>

          <a href="{{ block.settings.link }}">
            Explore →
          </a>
        </div>

      </div>

    {% endfor %}

  </div>

</section>


<style>

.split-showcase-{{ section.id }}{
  display:grid;
  grid-template-columns:300px 1fr;
  min-height:100vh;
}

.left-panel{
  position:sticky;
  top:0;
  height:100vh;
  padding:50px 30px;
  border-right:1px solid #eee;
}

.left-panel h2{
  font-size:34px;
  margin-bottom:40px;
}

.nav-item{
  display:block;
  text-decoration:none;
  color:black;
  margin-bottom:20px;
  font-size:18px;
  transition:.3s;
}

.nav-item:hover{
  padding-left:15px;
}

.right-panel{
  padding:40px;
}

.showcase-item{
  margin-bottom:100px;
}

.image-box{
  overflow:hidden;
  border-radius:20px;
}

.image-box img{
  width:100%;
  height:420px;
  object-fit:cover;
  transition:.5s;
}

.showcase-item:hover img{
  transform:scale(1.05);
}

.content-box{
  padding-top:25px;
}

.content-box h3{
  font-size:30px;
}

.content-box p{
  max-width:600px;
  line-height:1.7;
}

@media(max-width:991px){

  .split-showcase-{{ section.id }}{
    grid-template-columns:1fr;
  }

  .left-panel{
    position:relative;
    height:auto;
    border:none;
  }

  .image-box img{
    height:300px;
  }

}

</style>


{% schema %}
{
  "name":"Luxury Split Showcase",
  "settings":[
    {
      "type":"text",
      "id":"heading",
      "label":"Heading",
      "default":"Featured Collections"
    }
  ],
  "blocks":[
    {
      "type":"item",
      "name":"Showcase Item",
      "settings":[
        {
          "type":"text",
          "id":"title",
          "label":"Title"
        },
        {
          "type":"textarea",
          "id":"description",
          "label":"Description"
        },
        {
          "type":"image_picker",
          "id":"image",
          "label":"Image"
        },
        {
          "type":"url",
          "id":"link",
          "label":"Link"
        }
      ]
    }
  ],
  "presets":[
    {
      "name":"Luxury Split Showcase"
    }
  ]
}
{% endschema %}