<style>

.footer{
    width:100%;
    background-color:#556566;
    color:white;
    padding:70px 40px 25px;
}


.footer-grid{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:40px;
    margin-bottom:50px;
}


.footer-logo h2{
    font-size:32px;
    margin-bottom:15px;
}

.footer-logo p{
    color:#d8dede;
    line-height:1.8;
    font-size:14px;
}


.footer-links h3{
    margin-bottom:20px;
    font-size:20px;
}


.footer-links ul{
    list-style:none;
    padding:0;
    margin:0;
}

.footer-links ul li{
    margin-bottom:12px;
}

.footer-links ul li a{
    text-decoration:none;
    color:#d8dede;
    transition:0.3s;
    font-size:14px;
}

.footer-links ul li a:hover{
    color:white;
}


.newsletter-box input{
    width:100%;
    padding:13px;
    border:none;
    border-radius:50px;
    margin-bottom:15px;
    outline:none;
}

.newsletter-box button{
    width:100%;
    background-color:white;
    color:#556566;
    border:none;
    padding:13px;
    border-radius:50px;
    cursor:pointer;
    font-weight:600;
    transition:0.3s;
}

.newsletter-box button:hover{
    background-color:#d8dede;
}


.footer-bottom{
    border-top:1px solid rgba(255,255,255,0.2);
    padding-top:25px;
    text-align:center;
    font-size:14px;
    color:#d8dede;
}

/* RESPONSIVE */

@media (max-width: 992px){
    .footer-grid{
        grid-template-columns:repeat(2,1fr);
        gap:30px;
    }

    .footer{
        padding:60px 30px 25px;
    }
}

@media (max-width: 768px){
    .footer-grid{
        grid-template-columns:1fr;
        gap:25px;
    }

    .footer{
        padding:50px 20px 20px;
    }

    .footer-logo h2{
        font-size:28px;
    }

    .footer-links h3{
        font-size:18px;
    }
}

@media (max-width: 480px){
    .newsletter-box input,
    .newsletter-box button{
        padding:12px;
        font-size:14px;
    }

    .footer-bottom{
        font-size:12px;
    }
}

</style>

<div class="footer">

    <div class="footer-grid">

        <div class="footer-logo">

            <h2>Kitchenix</h2>

            <p>
                Premium kitchen essentials crafted for modern homes. 
                Explore cookware, dinnerware, and stylish kitchen tools.
            </p>

        </div>

        <div class="footer-links">

            <h3>Quick Links</h3>

            <ul>
                <li><a href="#">Home</a></li>
                <li><a href="#">Collections</a></li>
                <li><a href="#">Products</a></li>
                <li><a href="#">Contact</a></li>
            </ul>

        </div>

        <div class="footer-links">

            <h3>Policies</h3>

            <ul>
                <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
                <li><a href="/policies/refund-policy">Refund Policy</a></li>
                <li><a href="/policies/shipping-policy">Shipping Policy</a></li>
                <li><a href="/policies/terms-of-service">Terms & Conditions</a></li>
            </ul>

        </div>

        <div class="footer-links">

            <h3>Newsletter</h3>

            <div class="newsletter-box">

                <input type="email" placeholder="Enter your email">

                <button>Subscribe</button>

            </div>

        </div>

    </div>

    <div class="footer-bottom">
        © 2026 Kitchenix. All Rights Reserved.
    </div>

</div>

{% schema %}
{
  "name": "Kitchen Footer",
  "settings": [],
  "presets": [
    {
      "name": "Kitchen Footer"
    }
  ]
}
{% endschema %}