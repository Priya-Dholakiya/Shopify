<style>

.collection-section{
    width:100%;
    padding:70px 40px;
    background-color:#f5f7f7;
}

.collection-heading{
    text-align:center;
    margin-bottom:45px;
}

.collection-heading h2{
    font-size:38px;
    color:#2d3436;
    margin-bottom:10px;
}

.collection-heading p{
    color:#6e7f80;
    font-size:15px;
}

/* Collection Grid */

.collection-grid{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:30px;
}

/* Card */

.collection-card{
    position:relative;
    overflow:hidden;
    border-radius:25px;
}

.collection-card img{
    width:100%;
    height:450px;
    object-fit:cover;
    transition:0.4s;
}

.collection-card:hover img{
    transform:scale(1.05);
}

/* Overlay */

.collection-overlay{
    position:absolute;
    bottom:0;
    left:0;
    width:100%;
    padding:30px;
    background:linear-gradient(transparent,rgba(0,0,0,0.75));
}

.collection-overlay h3{
    color:white;
    font-size:28px;
    margin-bottom:10px;
}

.collection-overlay a{
    text-decoration:none;
    background-color:#6e7f80;
    color:white;
    padding:11px 24px;
    border-radius:50px;
    display:inline-block;
    font-size:14px;
    transition:0.3s;
}

.collection-overlay a:hover{
    background-color:white;
    color:black;
}

/* RESPONSIVE */

@media(max-width:992px){

    .collection-grid{
        grid-template-columns:repeat(2,1fr);
    }

    .collection-card img{
        height:380px;
    }

    .collection-section{
        padding:60px 30px;
    }
}

@media(max-width:576px){

    .collection-section{
        padding:50px 20px;
    }

    .collection-heading h2{
        font-size:28px;
    }

    .collection-heading p{
        font-size:14px;
        line-height:1.6;
    }

    .collection-grid{
        grid-template-columns:1fr;
        gap:20px;
    }

    .collection-card img{
        height:300px;
    }

    .collection-overlay{
        padding:20px;
    }

    .collection-overlay h3{
        font-size:22px;
    }

    .collection-overlay a{
        padding:10px 18px;
        font-size:13px;
    }

}

</style>

<div class="collection-section">

    <div class="collection-heading">
        <h2>Shop By Collection</h2>
        <p>Explore premium kitchen essentials crafted for modern homes.</p>
    </div>

    <div class="collection-grid">

        {% for block in section.blocks %}

        <div class="collection-card">

            <img src="{{ block.settings.collection_image | image_url }}">

            <div class="collection-overlay">

                <h3>{{ block.settings.collection_title }}</h3>

                <a href="{{ block.settings.collection_link }}">
                    Explore →
                </a>

            </div>

        </div>

        {% endfor %}

    </div>

</div>

{% schema %}
{
  "name": "Kitchen Collections",
  "settings": [],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "image_picker",
          "id": "collection_image",
          "label": "Collection Image"
        },
        {
          "type": "text",
          "id": "collection_title",
          "label": "Collection Title"
        },
        {
          "type": "url",
          "id": "collection_link",
          "label": "Collection Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kitchen Collections"
    }
  ]
}
{% endschema %}