<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/gh/kenwheeler/slick@1.8.1/slick/slick.css"/>

<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/gh/kenwheeler/slick@1.8.1/slick/slick-theme.css"/>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

<script type="text/javascript" src="https://cdn.jsdelivr.net/gh/kenwheeler/slick@1.8.1/slick/slick.min.js"></script>

<style>

.main-div{
    width:100%;
}

.slide{
    position:relative;
}

.slide img{
    width:100%;
    height:500px;
    object-fit:cover;
}

.explore-btn{
    position:absolute;
    bottom:40px;
    left:50%;
    transform:translateX(-50%);
}

.explore-btn button{
    background-color:#6b6b6b;
    color:white;
    border:none;
    padding:14px 35px;
    border-radius:50px;
    font-size:16px;
    cursor:pointer;
    transition:0.3s;
}

.explore-btn button:hover{
    background-color:black;
}

/* RESPONSIVE */

@media(max-width:992px){

    .slide img{
        height:400px;
    }

}

@media(max-width:576px){

    .slide img{
        height:250px;
    }

    .explore-btn{
        bottom:20px;
    }

    .explore-btn button{
        padding:10px 22px;
        font-size:14px;
    }

}

</style>

<div class="main-div">

    {% for block in section.blocks %}

    <div class="slide">

        <img src="{{ block.settings.slider_image | image_url }}">

        <div class="explore-btn">
            <button>Explore →</button>
        </div>

    </div>

    {% endfor %}

</div>

<script>

$(document).ready(function(){

    $('.main-div').slick({
        dots:true,
        infinite:true,
        speed:500,
        slidesToShow:1,
        autoplay:true,
        autoplaySpeed:2000,
        arrows:false
    });

});

</script>

{% schema %}
{
  "name": "Kitchen Slider",
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "slider_image",
          "label": "Select Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kitchen Slider"
    }
  ]
}
{% endschema %}